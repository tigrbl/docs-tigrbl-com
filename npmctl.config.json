{
  "schemaVersion": 1,
  "site": "docs.tigrbl.com",
  "repository": "tigrbl/docs-tigrbl-com",
  "orchestrator": "npmctl-pypi",
  "dns": {
    "provider": "namecheap",
    "zone": "tigrbl.com",
    "records": [
      {
        "type": "CNAME",
        "host": "docs",
        "value": "nginx.bz23.xyz",
        "ttl": 300
      }
    ],
    "providerPackage": "npmctl-namecheap"
  },
  "deploy": {
    "target": "self-hosted-docker",
    "service": "docs-tigrbl-com",
    "composeFile": "docker-compose.yaml",
    "proxyManager": {
      "provider": "nginx-proxy-manager",
      "apiEndpoint": "https://nginx.bz23.xyz/"
    }
  },
  "commands": {
    "install": "npm ci",
    "check": "npm run check",
    "build": "npm run build",
    "docker:build": "docker compose build docs-tigrbl-com",
    "dns:plan": "npmctl plan desired-state/dns.yaml --owner docs-tigrbl-com",
    "deploy:dry-run": "node scripts/deploy.mjs --dry-run",
    "deploy": "docker compose up -d --build --force-recreate --no-deps docs-tigrbl-com",
    "npmctl:install": "python -m pip install --upgrade npmctl npmctl-namecheap",
    "npmctl:validate": "npmctl validate desired-state",
    "npmctl:schema": "npmctl schema check",
    "dns:doctor": "npmctl dns doctor --provider namecheap",
    "dns:apply": "npmctl apply desired-state/dns.yaml --owner docs-tigrbl-com",
    "proxy:validate": "npmctl validate desired-state/proxy.yaml",
    "proxy:plan": "npmctl plan desired-state/proxy.yaml --owner docs-tigrbl-com",
    "proxy:apply": "npmctl apply desired-state/proxy.yaml --owner docs-tigrbl-com"
  },
  "npmctl": {
    "package": "npmctl",
    "dnsProviderPackage": "npmctl-namecheap",
    "installCommand": "python -m pip install --upgrade npmctl npmctl-namecheap",
    "proxyManagerApiEndpoint": "https://nginx.bz23.xyz/"
  }
}
