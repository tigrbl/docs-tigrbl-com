{
  "name": "docs-tigrbl-com",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node scripts/build-zdx.mjs",
    "check": "node scripts/check-docs.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "docker:build": "docker compose build docs-tigrbl-com",
    "dns:plan": "node scripts/namecheap-dns.mjs --plan",
    "dns:apply": "node scripts/namecheap-dns.mjs --apply",
    "deploy:dry-run": "node scripts/deploy.mjs --dry-run",
    "deploy": "docker compose -f docker-compose.yaml up -d --build --force-recreate --no-deps docs-tigrbl-com",
    "npmctl:install": "npmctl install",
    "npmctl:check": "npmctl check",
    "npmctl:build": "npmctl build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
